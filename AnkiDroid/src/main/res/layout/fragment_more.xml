<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:statusBarForeground="?attr/appBarColor"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/bottom_nav_more"
            app:titleTextAppearance="?attr/textAppearanceTitleLarge" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/more_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_settings_black"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="16dp" />

            <!-- Help section -->
            <com.ichi2.ui.FixedTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:text="@string/help"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/more_help_manual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_manual_black_24dp"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_title_using_ankidroid"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/more_help_get_help"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_help_black_24dp"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_title_get_help"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/more_help_community"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_people_black_24dp"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_title_community"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/more_help_privacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_baseline_privacy_tip_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_title_privacy"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="16dp" />

            <!-- Support section -->
            <com.ichi2.ui.FixedTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:text="@string/help_title_support_ankidroid"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/more_support_donate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_round_favorite_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_item_support_opencollective_donate"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/more_support_translate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_language_black_24dp"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/multimedia_editor_trans_translate"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/more_support_develop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_build_black_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_item_support_develop_ankidroid"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/more_support_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_star_black_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_item_support_rate_ankidroid"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/more_support_other"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_help_black_24dp"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_item_support_other_ankidroid"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/more_support_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_email_black_24dp"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/send_feedback"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
